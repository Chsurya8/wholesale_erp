body{
background:#f4f6f9;
font-family:Segoe UI;
}

.card{
border:none;
border-radius:12px;
box-shadow:0 3px 10px rgba(0,0,0,0.1);
}

.dashboard-card{
color:white;
padding:20px;
border-radius:10px;
}

.products{
background:#3498db;
}

.customers{
background:#27ae60;
}

.orders{
background:#e67e22;
}

.nav-btn{
color:white;
margin-left:10px;
background:#007bff;
border-radius:8px;
}

.nav-btn:hover{
background:#0056b3;
}

.table{
background:white;
border-radius:10px;
overflow:hidden;
}

button{
border-radius:8px;
}

.page-title{
font-size:28px;
font-weight:bold;
margin-bottom:20px;
}